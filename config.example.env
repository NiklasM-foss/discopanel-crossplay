# Environment for the systemd service. Installed to /etc/discopanel-crossplay.env
# (root-owned, chmod 600). Do NOT commit real secrets.

# DiscoPanel API (the app runs on the host, so localhost works)
DP_URL=http://127.0.0.1:8080
DP_TOKEN=dp_xxxxxxxxxxxxxxxxxxxxxxxx

# Where DiscoPanel stores server data on the host
HOST_DATA_ROOT=/opt/discopanel/data/servers

# Public IP that MCXboxBroadcast advertises to Bedrock/Xbox friends
MCXBOX_IP=87.106.60.148

# Bedrock UDP port range (already forwarded end-to-end by the gateway)
BEDROCK_BASE=19132
BEDROCK_MAX=19199

# DiscoPanel proxy listener id used for Java routing
PROXY_LISTENER=default

# Web UI bind address
BIND_HOST=0.0.0.0
BIND_PORT=5005

# Default Chunky world pre-generation radius in blocks (0 disables). The form can
# override this per server.
CHUNKY_RADIUS=1000
